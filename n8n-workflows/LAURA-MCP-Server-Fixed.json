        {
            "parameters": {
                "jsCode": "// Format availability response\nconst events = $input.all();\nconst zipCode = $('Router (Tool Selector)').first().json.body.zip_code;\nconst preferredDate = $('Router (Tool Selector)').first().json.body.preferred_date;\n\n// Build list of busy slots\nconst busySlots = events.map(e => ({\n  start: new Date(e.json.start.dateTime),\n  end: new Date(e.json.end.dateTime)\n}));\n\n// Generate available slots (9 AM - 5 PM, next 7 days)\nconst availableSlots = [];\nconst now = new Date();\n\nfor (let day = 0; day < 7; day++) {\n  const date = new Date(now);\n  date.setDate(date.getDate() + day);\n  \n  // Skip weekends (optional)\n  if (date.getDay() === 0 || date.getDay() === 6) continue;\n  \n  // Morning slots: 9 AM, 10 AM\n  [9, 10].forEach(hour => {\n    const slotStart = new Date(date);\n    slotStart.setHours(hour, 0, 0, 0);\n    const slotEnd = new Date(slotStart);\n    slotEnd.setHours(hour + 2); // 2-hour window\n    \n    // Check if slot is free\n    const isFree = !busySlots.some(busy => \n      (slotStart >= busy.start && slotStart < busy.end) ||\n      (slotEnd > busy.start && slotEnd <= busy.end)\n    );\n    \n    if (isFree && slotStart > now) {\n      availableSlots.push({\n        date: slotStart.toISOString().split('T')[0],\n        time: `${hour}:00 AM`,\n        datetime: slotStart.toISOString()\n      });\n    }\n  });\n  \n  // Afternoon slots: 2 PM, 3 PM\n  [14, 15].forEach(hour => {\n    const slotStart = new Date(date);\n    slotStart.setHours(hour, 0, 0, 0);\n    const slotEnd = new Date(slotStart);\n    slotEnd.setHours(hour + 2);\n    \n    const isFree = !busySlots.some(busy => \n      (slotStart >= busy.start && slotStart < busy.end) ||\n      (slotEnd > busy.start && slotEnd <= busy.end)\n    );\n    \n    if (isFree && slotStart > now) {\n      const displayHour = hour > 12 ? hour - 12 : hour;\n      availableSlots.push({\n        date: slotStart.toISOString().split('T')[0],\n        time: `${displayHour}:00 PM`,\n        datetime: slotStart.toISOString()\n      });\n    }\n  });\n}\n\nreturn {\n  json: {\n    available_slots: availableSlots.slice(0, 10), // Return top 10\n    next_available: availableSlots[0] ? `${availableSlots[0].date} at ${availableSlots[0].time}` : \"No availability in next 7 days\",\n    total_found: availableSlots.length\n  }\n};"
            },
