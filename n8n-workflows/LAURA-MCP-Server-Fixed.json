        {
            "parameters": {
                "jsCode": "// Pricing calculation logic\nconst input = $('Router (Tool Selector)').first().json.body;\nconst bedrooms = parseInt(input.bedrooms) || 2;\nconst bathrooms = parseInt(input.bathrooms) || 1;\nconst serviceType = input.service_type || 'regular';\nconst zipCode = input.zip_code || '';\n\n// Pricing Matrix (simplified)\nconst pricingMatrix = {\n  'regular': {\n    base: 100,\n    perBedroom: 30,\n    perBathroom: 20\n  },\n  'deep': {\n    base: 200,\n    perBedroom: 50,\n    perBathroom: 30\n  },\n  'move-in-out': {\n    base: 250,\n    perBedroom: 60,\n    perBathroom: 35\n  }\n};\n\nconst pricing = pricingMatrix[serviceType] || pricingMatrix['regular'];\n\n// Calculate base price\nlet basePrice = pricing.base + \n                (bedrooms * pricing.perBedroom) + \n                (bathrooms * pricing.perBathroom);\n\n// Check if premium area (simplified - can be enhanced with real zip lookup)\nconst premiumZips = ['30022', '30067', '30076', '30342', '30327'];\nconst isPremium = premiumZips.includes(zipCode);\nconst areaPremium = isPremium ? 0.15 : 0;\n\nif (isPremium) {\n  basePrice *= 1.15;\n}\n\n// Enforce minimum\nconst finalPrice = Math.max(basePrice, 150);\n\n// Calculate range (±5%)\nconst rangeLow = Math.round(finalPrice * 0.95);\nconst rangeHigh = Math.round(finalPrice * 1.05);\n\nreturn {\n  json: {\n    base_price: Math.round(finalPrice),\n    range_low: rangeLow,\n    range_high: rangeHigh,\n    area_premium: areaPremium,\n    discount_available: 0.10, // 10% max\n    breakdown: {\n      bedrooms: bedrooms,\n      bathrooms: bathrooms,\n      service_type: serviceType,\n      is_premium_area: isPremium\n    }\n  }\n};"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                680,
