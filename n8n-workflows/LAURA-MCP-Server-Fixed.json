        {
            "parameters": {
                "jsCode": "// Format check_lead response\nconst leads = $input.all();\nconst lead = leads[0]?.json || {};\n\nif (leads.length === 0 || !lead.id) {\n  return {\n    json: {\n      type: \"NEW\",\n      message: \"No previous history found\",\n      total_bookings: 0\n    }\n  };\n}\n\nconst bookingCount = leads.length;\n\n// Determine lead type\nlet leadType = \"NEW\";\nif (bookingCount > 3) {\n  leadType = \"RETURNING\";\n} else if (bookingCount > 0) {\n  const lastDate = new Date(lead.created_at);\n  const daysSince = (Date.now() - lastDate.getTime()) / (1000 * 60 * 60 * 24);\n  leadType = daysSince > 90 ? \"COLD\" : \"RETURNING\";\n}\n\nreturn {\n  json: {\n    type: leadType,\n    last_service_date: lead.created_at,\n    total_bookings: bookingCount,\n    preferred_day: lead.preferences?.preferred_day || null,\n    notes: lead.notes || null,\n    address: lead.address || null\n  }\n};"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                900,
                100
            ],
            "id": "format-check-lead",
            "name": "Format Response (check_lead)"
        },
