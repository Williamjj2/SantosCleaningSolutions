# API proxy to Netlify Functions
/api/*  /.netlify/functions/api/:splat  200

# Legacy URL redirects
/services/regular-cleaning/*  /regular-cleaning/:splat  301
/services/deep-cleaning/*     /deep-cleaning/:splat     301
/services/move-cleaning/*     /move-in-out-cleaning/:splat  301
/privacy-policy/*             /legal/privacy-policy/:splat  301
/terms-of-service/*           /legal/terms-of-service/:splat  301
/cancellation-policy/*        /legal/cancellation-policy/:splat  301
/disclaimer/*                 /legal/disclaimer/:splat  301

# SPA fallback - must be last
/*  /index.html  200
