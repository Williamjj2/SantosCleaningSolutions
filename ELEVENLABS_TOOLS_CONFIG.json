[
    {
        "name": "check_lead",
        "description": "Check if customer has history with us. Use when they mention past service or to personalize the call.",
        "url": "https://n8n.williamjj.com/webhook/laura",
        "method": "POST",
        "body_schema": {
            "properties": {
                "tool": {
                    "type": "string",
                    "const": "check_lead"
                },
                "phone": {
                    "type": "string",
                    "description": "Customer phone number in (XXX) XXX-XXXX format"
                }
            },
            "required": [
                "tool",
                "phone"
            ]
        }
    },
    {
        "name": "get_availability",
        "description": "Get available time slots for the next 7 days. Use when customer asks 'when are you free?' or rejects an offered time.",
        "url": "https://n8n.williamjj.com/webhook/laura",
        "method": "POST",
        "body_schema": {
            "properties": {
                "tool": {
                    "type": "string",
                    "const": "get_availability"
                },
                "zip_code": {
                    "type": "string",
                    "description": "Customer Zip Code to check service area availability"
                },
                "preferred_date": {
                    "type": "string",
                    "description": "Optional: Preferred date in YYYY-MM-DD format"
                }
            },
            "required": [
                "tool",
                "zip_code"
            ]
        }
    },
    {
        "name": "get_pricing",
        "description": "Calculate estimated price based on home details. Use when customer asks 'how much does it cost?'.",
        "url": "https://n8n.williamjj.com/webhook/laura",
        "method": "POST",
        "body_schema": {
            "properties": {
                "tool": {
                    "type": "string",
                    "const": "get_pricing"
                },
                "bedrooms": {
                    "type": "integer"
                },
                "bathrooms": {
                    "type": "integer"
                },
                "service_type": {
                    "type": "string",
                    "enum": [
                        "regular",
                        "deep",
                        "move-in-out"
                    ]
                },
                "zip_code": {
                    "type": "string"
                }
            },
            "required": [
                "tool",
                "bedrooms",
                "bathrooms",
                "service_type",
                "zip_code"
            ]
        }
    },
    {
        "name": "book_appointment",
        "description": "Book the cleaning appointment. Use ONLY when customer explicitly confirms a date and time.",
        "url": "https://n8n.williamjj.com/webhook/laura",
        "method": "POST",
        "body_schema": {
            "properties": {
                "tool": {
                    "type": "string",
                    "const": "book_appointment"
                },
                "phone": {
                    "type": "string"
                },
                "lead_name": {
                    "type": "string"
                },
                "service_type": {
                    "type": "string"
                },
                "address": {
                    "type": "string"
                },
                "datetime": {
                    "type": "string",
                    "description": "ISO 8601 Datetime (e.g. 2024-12-16T09:00:00Z)"
                },
                "price": {
                    "type": "number"
                }
            },
            "required": [
                "tool",
                "phone",
                "lead_name",
                "service_type",
                "address",
                "datetime",
                "price"
            ]
        }
    },
    {
        "name": "end_call",
        "description": "Log the call outcome at the very end of the conversation.",
        "url": "https://n8n.williamjj.com/webhook/laura",
        "method": "POST",
        "body_schema": {
            "properties": {
                "tool": {
                    "type": "string",
                    "const": "end_call"
                },
                "lead_id": {
                    "type": "string"
                },
                "outcome": {
                    "type": "string",
                    "enum": [
                        "booked",
                        "callback",
                        "not_interested",
                        "voicemail"
                    ]
                },
                "notes": {
                    "type": "string"
                }
            },
            "required": [
                "tool",
                "lead_id",
                "outcome",
                "notes"
            ]
        }
    }
]