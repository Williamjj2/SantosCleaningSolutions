### Row Level Security (RLS) Policies

```sql
-- Bills: Users can only see bills in their household
CREATE POLICY bills_household_access ON bills
  FOR SELECT
  USING (
    household_id IN (
      SELECT household_id FROM household_members
      WHERE user_id = auth.uid() AND status = 'active'
    )
  );

-- Bills: Users can only insert bills in their household
CREATE POLICY bills_insert ON bills
  FOR INSERT
  WITH CHECK (
    household_id IN (
      SELECT household_id FROM household_members
      WHERE user_id = auth.uid() AND status = 'active'
    )
  );

-- Notifications: Users only see their own notifications
CREATE POLICY notifications_user_access ON notifications
  FOR SELECT
  USING (user_id = auth.uid());

-- Subscriptions: Users only see their own subscription
CREATE POLICY subscriptions_user_access ON subscriptions
  FOR SELECT
  USING (user_id = auth.uid());
```

