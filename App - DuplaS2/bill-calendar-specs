## 💾 PARTE 4: DATABASE SCHEMA (COMPLETO)

### Tables

**1. USERS TABLE**
```sql
CREATE TABLE users (
  id UUID PRIMARY KEY,
  email VARCHAR(255) UNIQUE NOT NULL,
  name VARCHAR(100),
  avatar_url VARCHAR(500),
  phone VARCHAR(20),
  
  -- Preferences
  timezone VARCHAR(50) DEFAULT 'UTC',
  currency VARCHAR(3) DEFAULT 'USD',
  preferred_language VARCHAR(2) DEFAULT 'en',
  
  -- Subscription
  subscription_status VARCHAR(20) DEFAULT 'free',
  subscription_plan VARCHAR(20) DEFAULT 'free', -- free, pro, premium
  subscription_started_at TIMESTAMP,
  subscription_expires_at TIMESTAMP,
  
  -- Account
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  last_login_at TIMESTAMP,
  is_active BOOLEAN DEFAULT TRUE,
  email_verified BOOLEAN DEFAULT FALSE,
  
  CONSTRAINT check_status IN ('free', 'pro', 'premium', 'cancelled')
);

CREATE INDEX idx_users_email ON users(email);
CREATE INDEX idx_users_subscription ON users(subscription_status);
```

**2. HOUSEHOLDS TABLE**
```sql
CREATE TABLE households (
  id UUID PRIMARY KEY,
  name VARCHAR(100), -- "Sarah & Mike"
  created_by UUID NOT NULL REFERENCES users(id),
  
  -- Settings
  settings JSONB DEFAULT '{
    "shared_categories": true,
    "show_split_amounts": true,
    "currency": "USD"
  }',
  
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  
  FOREIGN KEY (created_by) REFERENCES users(id)
);

CREATE INDEX idx_households_creator ON households(created_by);
```

**3. HOUSEHOLD_MEMBERS TABLE**
```sql
CREATE TABLE household_members (
  id UUID PRIMARY KEY,
  household_id UUID NOT NULL REFERENCES households(id),
  user_id UUID NOT NULL REFERENCES users(id),
  
  -- Invite status
  status VARCHAR(20) DEFAULT 'active', -- pending, active, removed
  invited_at TIMESTAMP DEFAULT NOW(),
  accepted_at TIMESTAMP,
  role VARCHAR(20) DEFAULT 'member', -- creator, member
  
  -- Unique pair
  UNIQUE(household_id, user_id),
  
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW()
);

CREATE INDEX idx_members_household ON household_members(household_id);
CREATE INDEX idx_members_user ON household_members(user_id);
CREATE INDEX idx_members_status ON household_members(status);
```

**4. BILLS TABLE**
```sql
CREATE TABLE bills (
  id UUID PRIMARY KEY,
  household_id UUID NOT NULL REFERENCES households(id),
  created_by UUID NOT NULL REFERENCES users(id),
  
  -- Bill Info
  name VARCHAR(100) NOT NULL, -- "Rent", "Netflix"
  description TEXT,
  amount DECIMAL(10, 2) NOT NULL,
  currency VARCHAR(3) DEFAULT 'USD',
  category VARCHAR(50), -- housing, utilities, insurance, entertainment, etc
  
  -- Recurrence
  frequency VARCHAR(20) NOT NULL, -- daily, weekly, biweekly, monthly, quarterly, yearly, once
  day_of_month INTEGER, -- 1-31 for monthly
  day_of_week VARCHAR(10), -- mon, tue, etc for weekly
  start_date DATE NOT NULL,
  end_date DATE, -- NULL = indefinite
  
  -- Split
  paid_by_user VARCHAR(20) DEFAULT 'both', -- user1, user2, both
  split_percentage DECIMAL(5, 2) DEFAULT 50, -- user1 pays X%, user2 pays 100-X%
  
  -- Status
  is_active BOOLEAN DEFAULT TRUE,
  is_paid BOOLEAN DEFAULT FALSE,
  paid_date TIMESTAMP,
  paid_by UUID REFERENCES users(id),
  
  -- Notifications
  notify_days_before TEXT DEFAULT '[5, 2, 1]', -- JSON array
  last_notified_at TIMESTAMP,
  
  -- Metadata
